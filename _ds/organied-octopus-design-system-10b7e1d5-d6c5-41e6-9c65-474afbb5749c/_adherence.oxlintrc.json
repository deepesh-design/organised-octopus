{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/commerce/**",
              "components/navigation/**",
              "ui_kits/storefront/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:BDOGrotesk))/i]",
        "message": "Font not provided by the design system. Available: BDOGrotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='CartDrawer'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|children|key|ref|className|style|children)$/]",
        "message": "<CartDrawer> doesn't accept that prop. Declared props: open, onClose, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CollectionNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|name|active|onClick|key|ref|className|style|children)$/]",
        "message": "<CollectionNavItem> doesn't accept that prop. Declared props: index, name, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClick|dark|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: open, onClick, dark."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<MenuLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductThumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|name|selected|onClick|width|key|ref|className|style|children)$/]",
        "message": "<ProductThumb> doesn't accept that prop. Declared props: src, alt, name, selected, onClick, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShopButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|href|onClick|disabled|key|ref|className|style|children)$/]",
        "message": "<ShopButton> doesn't accept that prop. Declared props: label, value, href, onClick, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<FooterLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|menuOpen|onToggleMenu|homeHref|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: logoSrc, menuOpen, onToggleMenu, homeHref."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "CartDrawer": {
        "replaces": []
      },
      "CollectionNavItem": {
        "replaces": []
      },
      "IconButton": {
        "replaces": []
      },
      "MenuLink": {
        "replaces": []
      },
      "ProductThumb": {
